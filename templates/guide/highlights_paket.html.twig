{% extends 'base.html.twig' %}
{% import 'guide/_cards.html.twig' as cards %}

{% block title %}Tripora - Highlights-Paket{% endblock %}
{% block description %}Highlights-Paket – kuratierte Pakete pro Stadt (coming soon).{% endblock %}

{% block body %}
    {% set activeSlug = selectedCity ? selectedCity.citySlug : '' %}

    <div class="places-page highlights-page">
        <header class="site-header">
            <div class="nav-inner" aria-label="Hauptnavigation">
                <a class="brand" href="/" aria-label="Tripora">
                    <img
                        class="brand-logo"
                        src="/assets/logos/tripora_logo_v3_header.png"
                        alt="Tripora"
                        loading="eager"
                        decoding="async"
                    >
                </a>
                <nav class="main-nav" aria-label="Bereiche">
                    <a href="/einzelattraktion">Einzelattraktion</a>
                    <a href="/highlights-paket" aria-current="page">Highlights-Paket</a>
                    <a href="/api/cities">API</a>
                </nav>
                <div class="nav-actions" aria-label="Schnellzugriff">
                    <a class="nav-action is-outline has-icon" href="#support">
                        <span class="nav-login-icon" aria-hidden="true"></span>
                        <span>Anmelden</span>
                    </a>
                </div>
            </div>
        </header>

        <main class="has-fixed-header-offset">
            <section class="feed-shell" id="support" aria-label="Highlights-Paket">
                <div class="section-heading is-left" aria-label="Highlights-Paket">
                    <h2>Highlights-Paket</h2>
                    <p>Kuratierte Pakete im gleichen Kartenlayout wie die Einzelattraktionen.</p>
                </div>

                <form
                    class="search-panel home-search-panel is-compact"
                    action="{{ path('guide_einzelattraktion') }}"
                    method="get"
                    data-city-search
                    data-search-mode="spot"
                    data-city-action="{{ path('guide_highlights_paket') }}"
                    autocomplete="off"
                >
                    <div class="search-panel-title" role="tablist" aria-label="Suchmodus">
                        <button class="search-tab is-active" type="button" role="tab" aria-selected="true" data-search-tab="spot">
                            <span>Einzelattraktion</span>
                            <small>Spots suchen</small>
                        </button>
                        <button class="search-tab" type="button" role="tab" aria-selected="false" data-search-tab="city">
                            <span>City Guides</span>
                            <small>Städte suchen</small>
                        </button>
                    </div>
                    <div class="search-fields">
                        <span class="country-mark" aria-hidden="true">
                            <span></span>
                            <span></span>
                            <span></span>
                        </span>
                        <label>
                            <span class="sr-only">Stadt suchen</span>
                            <span class="search-field-label" data-search-field-label>Attraktion</span>
                            <input id="city-input" name="q" type="text" placeholder="Attraktion oder Spot suchen" autocomplete="off" spellcheck="false" data-city-input>
                        </label>
                        <button type="submit"><span>Suchen</span></button>
                    </div>
                    <div class="city-options" id="city-options" data-city-options aria-hidden="true"></div>
                </form>

                <section class="city-strip" aria-label="Wichtigste Städte">
                    {% for group in visibleCityGroups %}
                        {% set city = group.city %}
                        <a
                            class="city-card{{ city.citySlug == activeSlug ? ' is-active' : '' }}"
                            href="{{ path('guide_highlights_paket', { city: city.citySlug }) }}#places"
                            data-city-card
                            data-city-slug="{{ city.citySlug }}"
                        >
                            <strong>{{ city.cityDisplayLabel }}</strong>
                            <span>{{ city.cityRegion }}</span>
                        </a>
                    {% endfor %}
                </section>

                <section class="results-shell" id="places" aria-live="polite">
                    {% if cityNotFound %}
                        <div class="empty-state">
                            <strong>Keine passende Stadt gefunden.</strong>
                            <p>Wähle eine der kuratierten Städte oder suche nach einer anderen Schreibweise.</p>
                        </div>
                    {% endif %}

                    <section class="cool-place-grid spot-grid highlight-package-grid" aria-label="Highlights-Pakete">
                        {% for group in cityGroups|slice(0, 20) %}
                            {{ cards.highlight_package_card(group, activeSlug) }}
                        {% endfor %}
                    </section>
                </section>
            </section>
        </main>

        {% include 'partials/_footer.html.twig' %}
    </div>
{% endblock %}
